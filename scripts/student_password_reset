#!/usr/bin/env bash
set -euo pipefail

USER_NAME="student"
IMDS="http://169.254.169.254"

# Require root
if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
  echo "Error: must run as root (use sudo)." >&2
  exit 1
fi

# Ensure required commands exist
for cmd in curl chpasswd id; do
  command -v "$cmd" >/dev/null 2>&1 || { echo "Error: missing command: $cmd" >&2; exit 1; }
done

# Ensure user exists
if ! id "$USER_NAME" >/dev/null 2>&1; then
  echo "Error: user '$USER_NAME' does not exist." >&2
  exit 1
fi

# Fetch IMDSv2 token
TOKEN="$(curl -fsS --max-time 2 \
  -X PUT "$IMDS/latest/api/token" \
  -H "X-aws-ec2-metadata-token-ttl-seconds: 21600")"

# Fetch instance-id using token
INSTANCE_ID="$(curl -fsS --max-time 2 \
  -H "X-aws-ec2-metadata-token: $TOKEN" \
  "$IMDS/latest/meta-data/instance-id")"

if [[ -z "$INSTANCE_ID" ]]; then
  echo "Error: instance-id was empty." >&2
  exit 1
fi

# Set password: 'student:<instance-id>'
echo "${USER_NAME}:${INSTANCE_ID}" | chpasswd

# Optional: force password change at next login (comment out if undesired)
# chage -d 0 "$USER_NAME"

echo "Password for '${USER_NAME}' updated to the instance-id: ${INSTANCE_ID}"
